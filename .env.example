# ClipFactory API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Google AI Studio (Nano Banana 2 image generation)
# Get yours: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-key

# fal.ai (Kling animation + video generation)
# Get yours: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-ai-key

# HeyGen (UGC avatar talking heads) — optional
# Get yours: https://app.heygen.com/settings?nav=API
HEYGEN_API_KEY=your-heygen-api-key

# ElevenLabs (voiceovers) — optional
# Get yours: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key
